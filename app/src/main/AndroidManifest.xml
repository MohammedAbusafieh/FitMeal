<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.fitmeal">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="FitMeal"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FitMeal"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".GoalViewModel"
            android:exported="false" />
        <activity
            android:name=".RegisterActivity"
            android:exported="false" /> <!-- MainActivity is the launcher -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- SplashActivity stays but is not launcher -->
        <!-- Other app screens -->
        <activity
            android:name=".HomeActivity"
            android:exported="false"
            android:theme="@style/Theme.FitMeal" />
        <activity
            android:name=".MealPlannerActivity"
            android:exported="false"
            android:theme="@style/Theme.FitMeal" />
        <activity
            android:name=".GroceryListActivity"
            android:exported="false"
            android:theme="@style/Theme.FitMeal" />
        <activity
            android:name=".ProgressActivity"
            android:exported="false"
            android:theme="@style/Theme.FitMeal" />
        <activity
            android:name=".SetGoalActivity"
            android:exported="false"
            android:theme="@style/Theme.FitMeal" />
    </application>

</manifest>